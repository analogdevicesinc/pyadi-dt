	/* --- JESD204 RX — transport, link and physical layers --- */
	axi_jesd204_rx_0: axi-jesd204-rx@44a90000 {
		compatible = "adi,axi-jesd204-rx-1.0";
		reg = <0x0 0x44a90000 0x0 0x1000>;
		interrupts = <0 54 IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&zynqmp_clk 71>, <&hmc7044 10>, <&axi_clkgen_0 0>;
