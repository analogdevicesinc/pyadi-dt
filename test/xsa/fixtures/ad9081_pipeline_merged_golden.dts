		jesd204-device;
		#jesd204-cells = <2>;
		jesd204-inputs = <&axi_clkgen_0 0 0>;

		/* JESD204 framing: F = octets per frame per lane */
		adi,octets-per-frame = <4>;
		/* JESD204 framing: K = frames per multiframe (subclass 1: 17–256, must be multiple of 4) */
		adi,frames-per-multiframe = <32>;

		#sound-dai-cells = <0>;
	};
	/* --- JESD204 TX — transport, link and physical layers --- */
	axi_jesd204_tx_0: axi-jesd204-tx@44b90000 {
		compatible = "adi,axi-jesd204-tx-1.0";
		reg = <0x0 0x44b90000 0x0 0x1000>;
