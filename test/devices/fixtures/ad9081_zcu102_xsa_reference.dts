		clocks = <&hmc7044 12>;
		clock-names = "conv";
		clock-output-names = "rx_gt_clk", "rx_out_clk";
		jesd204-inputs = <&hmc7044 0 2>;
		adi,sys-clk-select = <3>;
		adi,out-clk-select = <4>;
		adi,use-lpm-enable;
	};
	&axi_mxfe_tx_dma {
		/delete-property/ compatible;
		compatible = "adi,axi-dmac-1.00.a";
		#dma-cells = <1>;
