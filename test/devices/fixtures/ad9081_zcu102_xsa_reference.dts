			adi,clkin1-buffer-mode = <0x07>;
			adi,oscin-buffer-mode = <0x15>;
			clock-output-names = "hmc7044_out0", "hmc7044_out1", "hmc7044_out2", "hmc7044_out3", "hmc7044_out4", "hmc7044_out5", "hmc7044_out6", "hmc7044_out7", "hmc7044_out8", "hmc7044_out9", "hmc7044_out10", "hmc7044_out11", "hmc7044_out12", "hmc7044_out13";
			hmc7044_c0: channel@0 {
				reg = <0>;
				adi,extended-name = "CORE_CLK_RX";
				adi,divider = <12>;
				adi,driver-mode = <2>;
			};
			hmc7044_c2: channel@2 {
				reg = <2>;
				adi,extended-name = "DEV_REFCLK";
				adi,divider = <12>;
				adi,driver-mode = <2>;
			};
			hmc7044_c3: channel@3 {
				reg = <3>;
				adi,extended-name = "DEV_SYSREF";
				adi,divider = <1536>;
				adi,driver-mode = <2>;
				adi,jesd204-sysref-chan;
			};
			hmc7044_c6: channel@6 {
				reg = <6>;
				adi,extended-name = "CORE_CLK_TX";
				adi,divider = <12>;
				adi,driver-mode = <2>;
			};
			hmc7044_c8: channel@8 {
				reg = <8>;
				adi,extended-name = "FPGA_REFCLK1";
				adi,divider = <6>;
				adi,driver-mode = <2>;
			};
			hmc7044_c10: channel@10 {
				reg = <10>;
				adi,extended-name = "CORE_CLK_RX_ALT";
				adi,divider = <12>;
				adi,driver-mode = <2>;
			};
			hmc7044_c12: channel@12 {
				reg = <12>;
				adi,extended-name = "FPGA_REFCLK2";
				adi,divider = <6>;
				adi,driver-mode = <2>;
			};
			hmc7044_c13: channel@13 {
				reg = <13>;
				adi,extended-name = "FPGA_SYSREF";
				adi,divider = <1536>;
				adi,driver-mode = <2>;
				adi,jesd204-sysref-chan;
			};
		};
	};
	&spi0 {
		status = "okay";
		#address-cells = <1>;
		#size-cells = <0>;
		trx0_ad9081: ad9081@0 {
			compatible = "adi,ad9081";
			#clock-cells = <1>;
			clock-output-names = "rx_sampl_clk", "tx_sampl_clk";
			#jesd204-cells = <2>;
			jesd204-top-device = <0>;
			jesd204-device;
			reg = <0>;
			reset-gpios = <&gpio 133 0>;
			sysref-req-gpios = <&gpio 121 0>;
			rx2-enable-gpios = <&gpio 135 0>;
			rx1-enable-gpios = <&gpio 134 0>;
			tx2-enable-gpios = <&gpio 137 0>;
			tx1-enable-gpios = <&gpio 136 0>;
			clocks = <&hmc7044 2>;
			clock-names = "dev_clk";
			jesd204-link-ids = <2 0>;
			jesd204-inputs = <&rx_mxfe_tpl_core_adc_tpl_core 0 2>, <&tx_mxfe_tpl_core_dac_tpl_core 0 0>;
			spi-max-frequency = <5000000>;
			adi,tx-dacs {
				#size-cells = <0>;
				#address-cells = <1>;
				adi,dac-frequency-hz = /bits/ 64 <12000000000>;
				adi,main-data-paths {
					#address-cells = <1>;
					#size-cells = <0>;
					adi,interpolation = <8>;
					dac@0 { reg = <0>; adi,crossbar-select = <0x28>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					dac@1 { reg = <1>; adi,crossbar-select = <0x29>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					dac@2 { reg = <2>; adi,crossbar-select = <0x2a>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					dac@3 { reg = <3>; adi,crossbar-select = <0x2b>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
				};
				adi,channelizer-paths {
					#address-cells = <1>;
					#size-cells = <0>;
					adi,interpolation = <6>;
					ad9081_tx_fddc_chan0: channel@0 { reg = <0>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_tx_fddc_chan1: channel@1 { reg = <1>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_tx_fddc_chan2: channel@2 { reg = <2>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_tx_fddc_chan3: channel@3 { reg = <3>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_tx_fddc_chan4: channel@4 { reg = <4>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_tx_fddc_chan5: channel@5 { reg = <5>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_tx_fddc_chan6: channel@6 { reg = <6>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_tx_fddc_chan7: channel@7 { reg = <7>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
				};
				adi,jesd-links {
					#size-cells = <0>;
					#address-cells = <1>;
					link@0 {
						reg = <0>;
						adi,converter-select = <&ad9081_tx_fddc_chan0 0>, <&ad9081_tx_fddc_chan0 1>, <&ad9081_tx_fddc_chan1 0>, <&ad9081_tx_fddc_chan1 1>, <&ad9081_tx_fddc_chan2 0>, <&ad9081_tx_fddc_chan2 1>, <&ad9081_tx_fddc_chan3 0>, <&ad9081_tx_fddc_chan3 1>;
						adi,logical-lane-mapping = /bits/ 8 <0 2 7 7 1 7 7 3>;
						adi,link-mode = <9>;
						adi,subclass = <1>;
						adi,version = <1>;
						adi,dual-link = <0>;
						adi,converters-per-device = <8>;
						adi,octets-per-frame = <4>;
						adi,frames-per-multiframe = <32>;
						adi,converter-resolution = <16>;
						adi,bits-per-sample = <16>;
						adi,control-bits-per-sample = <0>;
						adi,lanes-per-device = <4>;
						adi,samples-per-converter-per-frame = <1>;
						adi,high-density = <0>;
						adi,tpl-phase-adjust = <3>;
					};
				};
			};
			adi,rx-adcs {
				#size-cells = <0>;
				#address-cells = <1>;
				adi,adc-frequency-hz = /bits/ 64 <4000000000>;
				adi,main-data-paths {
					#address-cells = <1>;
					#size-cells = <0>;
					adc@0 { reg = <0>; adi,decimation = <4>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; adi,nco-mixer-mode = <0>; };
					adc@1 { reg = <1>; adi,decimation = <4>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; adi,nco-mixer-mode = <0>; };
					adc@2 { reg = <2>; adi,decimation = <4>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; adi,nco-mixer-mode = <0>; };
					adc@3 { reg = <3>; adi,decimation = <4>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; adi,nco-mixer-mode = <0>; };
				};
				adi,channelizer-paths {
					#address-cells = <1>;
					#size-cells = <0>;
					ad9081_rx_fddc_chan0: channel@0 { reg = <0>; adi,decimation = <4>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_rx_fddc_chan1: channel@1 { reg = <1>; adi,decimation = <4>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_rx_fddc_chan2: channel@2 { reg = <2>; adi,decimation = <4>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_rx_fddc_chan3: channel@3 { reg = <3>; adi,decimation = <4>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_rx_fddc_chan4: channel@4 { reg = <4>; adi,decimation = <4>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_rx_fddc_chan5: channel@5 { reg = <5>; adi,decimation = <4>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_rx_fddc_chan6: channel@6 { reg = <6>; adi,decimation = <4>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
					ad9081_rx_fddc_chan7: channel@7 { reg = <7>; adi,decimation = <4>; adi,gain = <2048>; adi,nco-frequency-shift-hz = /bits/ 64 <0>; };
				};
				adi,jesd-links {
					#size-cells = <0>;
					#address-cells = <1>;
					link@0 {
						reg = <0>;
						adi,converter-select = <&ad9081_rx_fddc_chan0 0>, <&ad9081_rx_fddc_chan0 1>, <&ad9081_rx_fddc_chan1 0>, <&ad9081_rx_fddc_chan1 1>, <&ad9081_rx_fddc_chan2 0>, <&ad9081_rx_fddc_chan2 1>, <&ad9081_rx_fddc_chan3 0>, <&ad9081_rx_fddc_chan3 1>;
						adi,logical-lane-mapping = /bits/ 8 <2 0 7 7 7 7 3 1>;
						adi,link-mode = <10>;
						adi,subclass = <1>;
						adi,version = <1>;
						adi,dual-link = <0>;
						adi,converters-per-device = <8>;
						adi,octets-per-frame = <4>;
						adi,frames-per-multiframe = <32>;
						adi,converter-resolution = <16>;
						adi,bits-per-sample = <16>;
						adi,control-bits-per-sample = <0>;
						adi,lanes-per-device = <4>;
						adi,samples-per-converter-per-frame = <1>;
						adi,high-density = <0>;
					};
				};
			};
		};
	};
	&axi_mxfe_rx_dma {
		/delete-property/ compatible;
		compatible = "adi,axi-dmac-1.00.a";
		#dma-cells = <1>;
		#clock-cells = <0>;
	};
	&rx_mxfe_tpl_core_adc_tpl_core {
		/delete-property/ compatible;
		/delete-property/ clocks;
		/delete-property/ clock-names;
		#jesd204-cells = <2>;
		jesd204-device;
		dmas = <&axi_mxfe_rx_dma 0>;
		dma-names = "rx";
		spibus-connected = <&trx0_ad9081>;
		jesd204-inputs = <&axi_mxfe_rx_jesd_rx_axi 0 2>;
		compatible = "adi,axi-ad9081-rx-1.0";
	};
	&axi_mxfe_rx_xcvr {
		/delete-property/ compatible;
		/delete-property/ clocks;
		/delete-property/ clock-names;
		/delete-property/ #clock-cells;
		/delete-property/ clock-output-names;
		/delete-property/ adi,sys-clk-select;
		/delete-property/ adi,out-clk-select;
