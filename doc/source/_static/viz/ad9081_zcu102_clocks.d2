}
hmc7044: {
  label: "hmc7044"
  shape: rectangle
  style.fill: "#1a3d5c"
  style.font-color: white
}
trx0_ad9081: {
  label: "trx0_ad9081\n(ad9081)"
  shape: rectangle
  style.fill: "#5c1a1a"
