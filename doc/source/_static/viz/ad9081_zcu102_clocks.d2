  style.stroke: "#555555"
  style.stroke-dash: 5
}
hmc7044 -> axi_mxfe_tx_jesd_tx_axi: "device_clk[6]" {
  style.stroke: "#4a9eff"
}
axi_mxfe_tx_xcvr -> axi_mxfe_tx_jesd_tx_axi: "lane_clk[0]" {
  style.stroke: "#44cc44"
}
hmc7044 -> axi_mxfe_rx_xcvr: "conv[2]" {
  style.stroke: "#cc9944"
}
trx0_ad9081 -> tx_mxfe_tpl_core_dac_tpl_core: "sampl_clk[1]" {
  style.stroke: "#cc44cc"
}
