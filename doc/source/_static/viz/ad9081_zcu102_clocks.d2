  style.font-color: white
}
zynqmp_clk: {
  label: "zynqmp_clk"
  shape: oval
  style.fill: "#7a3800"
  style.font-color: white
}

hmc7044 -> trx0_ad9081: "dev_clk[2]" {
  style.stroke: "#888888"
}
zynqmp_clk -> axi_mxfe_rx_jesd_rx_axi: "s_axi_aclk[71]" {
  style.stroke: "#555555"
  style.stroke-dash: 5
}
hmc7044 -> axi_mxfe_rx_jesd_rx_axi: "device_clk[0]" {
  style.stroke: "#4a9eff"
}
axi_mxfe_rx_xcvr -> axi_mxfe_rx_jesd_rx_axi: "lane_clk[0]" {
  style.stroke: "#44cc44"
}
