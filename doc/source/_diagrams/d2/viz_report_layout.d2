report: HTML Topology Report {
  class: sw-container
  grid-rows: 3
  grid-columns: 2

  A: "DTS Node Tree\n(searchable)" {
    class: sw-step-blue
  }
  B: "XSA Match Coverage\n(stats)" {
    class: sw-step-blue
  }
  C: "Clock Topology\n(D3.js SVG)" {
    class: sw-step-blue
  }
  D: "JESD204 Data Path\n(D3.js SVG)" {
    class: sw-step-blue
  }
  E: "Details: Parsed Topology / Clock References / JESD Paths" {
    grid-column: 1 / span 2
    class: sw-step-white
  }
}
