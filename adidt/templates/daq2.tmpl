#include "{{ base_dts_include }}"
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/jesd204/adxcvr.h>
#include <dt-bindings/iio/adc/adi,ad9208.h>

/ {
	fragment@0 {
		target = <&i2c1>;
		__overlay__ {
			i2c-mux@75 {
				i2c@0 {
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0>;
					/* HPC0_IIC */
					ad7291@2f {
						compatible = "adi,ad7291";
						reg = <0x2f>;
					};

					eeprom@50 {
						compatible = "at24,24c02";
						reg = <0x50>;
					};

				};
			};
		};
	};

	fragment@1 {
		target = <&fpga_axi>;
		__overlay__ {
			rx_dma: dma-controller@9c400000 {
				compatible = "adi,axi-dmac-1.00.a";
				reg = <0x9c400000 0x10000>;
				#dma-cells = <1>;
				#clock-cells = <0>;
				dma-coherent;
				interrupts = <0 109 IRQ_TYPE_LEVEL_HIGH>;
				clocks = <&zynqmp_clk 71>;
			};

			tx_dma: dma-controller@9c420000 {
				compatible = "adi,axi-dmac-1.00.a";
				reg = <0x9c420000 0x10000>;
				#dma-cells = <1>;
				#clock-cells = <0>;
				dma-coherent;
				interrupts = <0 108 IRQ_TYPE_LEVEL_HIGH>;
				clocks = <&zynqmp_clk 71>;
			};

			axi_ad9144_core: axi-ad9144-hpc@84a04000{
				compatible = "adi,axi-ad9144-1.0";
				reg = <0x84a04000 0x10000>;
				dmas = <&tx_dma 0>;
				dma-names = "tx";
				spibus-connected = <&dac0_ad9144>;
				adi,axi-pl-fifo-enable;

				/* jesd204-fsm support */
				jesd204-device;
				#jesd204-cells = <2>;
				jesd204-inputs = <&axi_ad9144_jesd 1 0>;
			};

			axi_ad9144_jesd: axi-jesd204-tx@84a90000 {
				compatible = "adi,axi-jesd204-tx-1.0";
				reg = <0x84a90000 0x4000>;

				interrupts = <0 106 IRQ_TYPE_LEVEL_HIGH>;

				clocks = <&zynqmp_clk 71>, <&axi_ad9144_adxcvr 1>, <&axi_ad9144_adxcvr 0>;
				clock-names = "s_axi_aclk", "device_clk", "lane_clk";

				#clock-cells = <0>;
				clock-output-names = "jesd_dac_lane_clk";

				/* jesd204-fsm support */
				jesd204-device;
				#jesd204-cells = <2>;
				jesd204-inputs = <&axi_ad9144_adxcvr 1 0>;
			};

			axi_ad9680_core: axi-ad9680-hpc@84a10000 {
				compatible = "adi,axi-ad9680-1.0";
				reg = <0x84a10000 0x10000>;
				dmas = <&rx_dma 0>;
				dma-names = "rx";
				spibus-connected = <&adc0_ad9680>;

				/* jesd204-fsm support */
				jesd204-device;
				#jesd204-cells = <2>;
				jesd204-inputs = <&axi_ad9680_jesd 0 0>;
			};

			axi_ad9680_jesd: axi-jesd204-rx@84aa0000 {
				compatible = "adi,axi-jesd204-rx-1.0";
				reg = <0x84aa0000 0x4000>;

				interrupts = <0 107 IRQ_TYPE_LEVEL_HIGH>;

				clocks = <&zynqmp_clk 71>, <&axi_ad9680_adxcvr 1>, <&axi_ad9680_adxcvr 0>;
				clock-names = "s_axi_aclk", "device_clk", "lane_clk";

				#clock-cells = <0>;
				clock-output-names = "jesd_adc_lane_clk";

				/* jesd204-fsm support */
				jesd204-device;
				#jesd204-cells = <2>;
				jesd204-inputs = <&axi_ad9680_adxcvr 0 0>;
			};

			axi_ad9680_adxcvr: axi-adxcvr-rx@84a50000{
				compatible = "adi,axi-adxcvr-1.0";
				reg = <0x84A50000 0x1000>;

				clocks = <&clk0_ad9523 4>;
				clock-names = "conv";

				#clock-cells = <1>;
				clock-output-names = "adc_gt_clk", "rx_out_clk";

				adi,sys-clk-select = <XCVR_CPLL>;
				adi,out-clk-select = <XCVR_PROGDIV_CLK>;
				adi,use-lpm-enable;

				/* jesd204-fsm support */
				jesd204-device;
				#jesd204-cells = <2>;
			};

			axi_ad9144_adxcvr: axi-adxcvr-tx@84a60000{
				compatible = "adi,axi-adxcvr-1.0";
				reg = <0x84A60000 0x1000>;

				clocks = <&clk0_ad9523 9>;
				clock-names = "conv";

				#clock-cells = <1>;
				clock-output-names = "dac_gt_clk", "tx_out_clk";

				adi,sys-clk-select = <XCVR_QPLL>;
				adi,out-clk-select = <XCVR_PROGDIV_CLK>;
				adi,use-lpm-enable;

				/* jesd204-fsm support */
				jesd204-device;
				#jesd204-cells = <2>;
			};

			axi_sysid_0: axi-sysid-0@85000000 {
				compatible = "adi,axi-sysid-1.00.a";
				reg = <0x85000000 0x10000>;
			};
		};
	};

	fragment@2 {
		target = <&spi0>;
		__overlay__ {
			status = "okay";
		};
	};

	fragment@3 {
		target = <&dwc3_0>;
		__overlay__ {
			status = "okay";
			dr_mode = "otg";
		};
	};

	fragment@4 {
		target = <&fmc_spi>;
		__overlay__ {
			clk0_ad9523: ad9523-1@0 {
				#address-cells = <1>;
				#size-cells = <0>;
				compatible = "adi,ad9523-1";
				reg = <0>;

				spi-max-frequency = <10000000>;

				clock-output-names =
					"ad9523-1_out0", "ad9523-1_out1", "ad9523-1_out2",
					"ad9523-1_out3", "ad9523-1_out4", "ad9523-1_out5",
					"ad9523-1_out6", "ad9523-1_out7", "ad9523-1_out8",
					"ad9523-1_out9", "ad9523-1_out10", "ad9523-1_out11",
					"ad9523-1_out12", "ad9523-1_out13";
				#clock-cells = <1>;

				adi,vcxo-freq = <{{ clock['clock']['vcxo'] }}>;
				adi,spi-3wire-enable;
				adi,pll1-bypass-enable;
				adi,osc-in-diff-enable;

				adi,pll2-charge-pump-current-nA = <413000>;

				adi,pll2-m1-freq = <{{ (clock['clock']['vco']/clock['clock']['m1']) | int}}>;

				adi,rpole2 = <0>;
				adi,rzero = <7>;
				adi,cpole1 = <2>;

				{% for chan in clock['map'] %}
				ad9523_0_c{{ clock['map'][chan]['source_port'] }}:channel@{{ clock['map'][chan]['source_port'] }} {
					reg = <{{ clock['map'][chan]['source_port'] }}>;
					adi,extended-name = "{{ chan }}";
					adi,driver-mode = <3>;
					adi,divider-phase = <1>;
					adi,channel-divider = <{{ clock['map'][chan]['divider'] }}>;
				};
				{% endfor %}
			};

			dac0_ad9144: ad9144@1 {
				#address-cells = <1>;
				#size-cells = <0>;
				compatible = "adi,ad9144";
				reg = <1>;

				spi-max-frequency = <1000000>;

				clocks = <&clk0_ad9523 1>;
				clock-names = "dac_clk";

				adi,jesd-link-mode = <{{ dac['jesd']['jesd_mode'] }}>;
				adi,sysref-mode = <1>;
				adi,subclass = <1>;
				adi,interpolation = <{{ dac['interpolation'] }}>;
				adi,frequency-center-shift = <0>;

				jesd204-device;
				#jesd204-cells = <2>;
				jesd204-top-device = <1>;
				jesd204-link-ids = <0>;
				jesd204-inputs = <&axi_ad9144_core 1 0>;
			};

			adc0_ad9680: ad9680@2 {
				#address-cells = <1>;
				#size-cells = <0>;
				compatible = "adi,ad9680";
				reg = <2>;

				spi-max-frequency = <1000000>;

				clocks = <&axi_ad9680_jesd>, <&clk0_ad9523 13>, <&clk0_ad9523 5>;
				clock-names = "jesd_adc_clk", "adc_clk", "adc_sysref";

				jesd204-device;
				#jesd204-cells = <2>;
				jesd204-top-device = <0>;
				jesd204-link-ids = <0>;
				jesd204-inputs = <&axi_ad9680_core 0 0>;

				adi,powerdown-mode = <AD9208_PDN_MODE_POWERDOWN>;

				adi,sampling-frequency = <{{ adc['jesd']['converter_clock'] }}>;
				adi,input-clock-divider-ratio = <1>;

				adi,sysref-lmfc-offset = <0>;
				adi,sysref-pos-window-skew = <0>;
				adi,sysref-neg-window-skew = <0>;
				adi,sysref-mode = <AD9208_SYSREF_CONT>;
				adi,sysref-nshot-ignore-count = <0>;

				adi,converters-per-device = <{{ adc['jesd']['M'] }}>;
				adi,lanes-per-device = <{{ adc['jesd']['L'] }}>;
				adi,octets-per-frame = <{{ adc['jesd']['F'] }}>;
				adi,frames-per-multiframe = <{{ adc['jesd']['K'] }}>;
				adi,converter-resolution = <{{ adc['jesd']['Np'] }}>;
				adi,bits-per-sample = <{{ adc['jesd']['Np'] }}>;
				adi,control-bits-per-sample = <{{ adc['jesd']['M'] }}>;
				adi,subclass = <{{ adc['jesd']['jesd_class_int'] }}>;

				adi,ddc-channel-number = <AD9208_FULL_BANDWIDTH_MODE>;

				ad9208_ddc0: channel@0 {
					reg = <0>;
					adi,decimation = <{{ adc['decimation'] }}>;
					adi,nco-mode-select = <AD9208_NCO_MODE_VIF>;
					adi,nco-channel-carrier-frequency-hz = <70000000>;
					adi,nco-channel-phase-offset = <0>;
				};
			};
		};
	};

	fragment@5 {
		target = <&adc0_ad9680>;
		__overlay__ {
			powerdown-gpios = <&gpio 120 0>; /* 42 + 78 */
			fastdetect-a-gpios = <&gpio 113 0>; /* 35 */
			fastdetect-b-gpios = <&gpio 114 0>; /* 36 */
		};
	};

	fragment@6 {
		target = <&dac0_ad9144>;
		__overlay__ {
			txen-gpios = <&gpio 119 0>; /* 41 */
			reset-gpios = <&gpio 118 0>; /* 40 */
			irq-gpios = <&gpio 112 0>; /* 34 */
		};
	};

	fragment@7 {
		target = <&clk0_ad9523>;
		__overlay__ {
			sync-gpios = <&gpio 116 0>; /* 38 */
			status0-gpios = <&gpio 110 0>; /* 32 */
			status1-gpios = <&gpio 111 0>; /* 33 */
		};
	};
};
