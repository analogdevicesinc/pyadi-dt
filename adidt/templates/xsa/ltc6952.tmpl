{# LTC6952/LTC6953 clock distribution SPI device node — UNTESTED, generated from kernel binding iio/frequency/adi,ltc6952.yaml #}
		{{ label }}: {{ compatible_id | default("ltc6952") }}@{{ cs }} {
			compatible = "adi,{{ compatible_id | default("ltc6952") }}";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
			#clock-cells = <1>;
{%- if clks_str is not none %}
			clocks = {{ clks_str }};
			clock-names = "clkin";
{%- endif %}
{%- if clock_output_names_str is not none %}
			clock-output-names = {{ clock_output_names_str }};
{%- endif %}
{%- if vco_frequency_hz is defined and vco_frequency_hz is not none %}
			adi,vco-frequency-hz = <{{ vco_frequency_hz }}>;
{%- endif %}
{%- if ref_frequency_hz is defined and ref_frequency_hz is not none %}
			adi,ref-frequency-hz = <{{ ref_frequency_hz }}>;
{%- endif %}
{%- for ch in channels %}
			{{ label }}_c{{ ch.id }}: channel@{{ ch.id }} {
				reg = <{{ ch.id }}>;
				adi,extended-name = "{{ ch.name }}";
				adi,divider = <{{ ch.divider }}>;
{%- if ch.digital_delay is defined %}
				adi,digital-delay = <{{ ch.digital_delay }}>;
{%- endif %}
{%- if ch.analog_delay is defined %}
				adi,analog-delay = <{{ ch.analog_delay }}>;
{%- endif %}
			};
{%- endfor %}
		};
