{# ADF4030 precision synchronizer SPI device node — UNTESTED, generated from kernel binding iio/frequency/adi,adf4030.yaml #}
		{{ label }}: adf4030@{{ cs }} {
			compatible = "adi,adf4030";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
			#clock-cells = <1>;
{%- if clks_str is not none %}
			clocks = {{ clks_str }};
			clock-names = "refin";
{%- endif %}
{%- if clock_output_names_str is not none %}
			clock-output-names = {{ clock_output_names_str }};
{%- endif %}
{%- if vco_frequency_hz is defined and vco_frequency_hz is not none %}
			adi,vco-frequency-hz = <{{ vco_frequency_hz }}>;
{%- endif %}
{%- if bsync_frequency_hz is defined and bsync_frequency_hz is not none %}
			adi,bsync-frequency-hz = <{{ bsync_frequency_hz }}>;
{%- endif %}
{%- for ch in channels %}
			{{ label }}_c{{ ch.id }}: channel@{{ ch.id }} {
				reg = <{{ ch.id }}>;
				adi,extended-name = "{{ ch.name }}";
{%- if ch.divider is defined %}
				adi,divider = <{{ ch.divider }}>;
{%- endif %}
{%- if ch.delay_fs is defined %}
				adi,delay-fs = <{{ ch.delay_fs }}>;
{%- endif %}
{%- if ch.output_en is defined and ch.output_en %}
				adi,output-en;
{%- endif %}
			};
{%- endfor %}
		};
