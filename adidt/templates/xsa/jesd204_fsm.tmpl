	{{ instance.name | replace("-", "_") }}: axi-jesd204-{{ instance.direction }}@{{ "%08x" | format(instance.base_addr) }} {
		compatible = "adi,axi-jesd204-{{ instance.direction }}-1.0";
		reg = <{{ reg_addr(instance.base_addr) }} {{ reg_size(0x1000) }}>;
{%- if instance.irq is not none %}
		interrupts = <0 {{ instance.irq }} IRQ_TYPE_LEVEL_HIGH>;
{%- endif %}
		clocks = <&{{ ps_clk_label }}{% if ps_clk_index is not none %} {{ ps_clk_index }}{% endif %}>, <&{{ device_clk_label }} {{ device_clk_index }}>, <&{{ jesd_input_label }} 0>;
		clock-names = "s_axi_aclk", "device_clk", "lane_clk";
		#clock-cells = <0>;
		clock-output-names = "{{ instance.name | replace('-', '_') }}_lane_clk";
		jesd204-device;
		#jesd204-cells = <2>;
		jesd204-inputs = <&{{ jesd_input_label }} 0 {{ jesd_input_link_id }}>;

		/* JESD204 framing: F = octets per frame per lane */
		adi,octets-per-frame = <{{ jesd.F }}>;
		/* JESD204 framing: K = frames per multiframe (subclass 1: 17–256, must be multiple of 4) */
		adi,frames-per-multiframe = <{{ jesd.K }}>;

		#sound-dai-cells = <0>;
	};
