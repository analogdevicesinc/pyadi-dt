{# AD9739a RF DAC SPI device node — UNTESTED, generated from kernel binding iio/dac/adi,ad9739a.yaml #}
		{{ label }}: ad9739a@{{ cs }} {
			compatible = "adi,ad9739a";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
{%- if clks_str is not none %}
			clocks = {{ clks_str }};
{%- endif %}
{%- if full_scale_microamp is defined and full_scale_microamp is not none %}
			adi,full-scale-microamp = <{{ full_scale_microamp }}>;
{%- endif %}
{%- if reset_gpio is not none %}
			reset-gpios = <&{{ gpio_label }} {{ reset_gpio }} 0>;
{%- endif %}
		};
