{# ADMV1014 microwave downconverter SPI device node — UNTESTED, generated from kernel binding iio/frequency/adi,admv1014.yaml #}
		{{ label }}: admv1014@{{ cs }} {
			compatible = "adi,admv1014";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
{%- if clks_str is not none %}
			clocks = {{ clks_str }};
			clock-names = "lo_in";
{%- endif %}
{%- if input_mode is defined and input_mode is not none %}
			adi,input-mode = "{{ input_mode }}";
{%- endif %}
{%- if quad_se_mode is defined and quad_se_mode is not none %}
			adi,quad-se-mode = "{{ quad_se_mode }}";
{%- endif %}
{%- if detector_enable %}
			adi,detector-enable;
{%- endif %}
{%- if p1db_compensation_enable %}
			adi,p1db-compensation-enable;
{%- endif %}
		};
