{# ADF4350/ADF4351 wideband synthesizer SPI device node — UNTESTED, generated from kernel binding iio/frequency/adi,adf4350.yaml #}
		{{ label }}: {{ compatible_id | default("adf4350") }}@{{ cs }} {
			compatible = "adi,{{ compatible_id | default("adf4350") }}";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
			#clock-cells = <0>;
{%- if clks_str is not none %}
			clocks = {{ clks_str }};
			clock-names = "clkin";
{%- endif %}
{%- if channel_spacing is defined and channel_spacing is not none %}
			adi,channel-spacing = <{{ channel_spacing }}>;
{%- endif %}
{%- if power_up_frequency is defined and power_up_frequency is not none %}
			adi,power-up-frequency = <{{ power_up_frequency }}>;
{%- endif %}
{%- if output_power is defined and output_power is not none %}
			adi,output-power = <{{ output_power }}>;
{%- endif %}
{%- if charge_pump_current is defined and charge_pump_current is not none %}
			adi,charge-pump-current = <{{ charge_pump_current }}>;
{%- endif %}
{%- if muxout_select is defined and muxout_select is not none %}
			adi,muxout-select = <{{ muxout_select }}>;
{%- endif %}
		};
