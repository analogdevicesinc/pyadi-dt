{# AD9545 network clock SPI device node — UNTESTED, generated from kernel binding clock/clk-ad9545.yaml #}
{# Note: AD9545 is typically I2C but can be SPI. This template assumes SPI. #}
		{{ label }}: ad9545@{{ cs }} {
			compatible = "adi,ad9545";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
			#clock-cells = <2>;
{%- if clks_str is not none %}
			clocks = {{ clks_str }};
			clock-names = {{ clk_names_str }};
{%- endif %}
{%- if ref_frequency_hz is defined and ref_frequency_hz is not none %}
			adi,ref-frequency-hz = <{{ ref_frequency_hz }}>;
{%- endif %}
{%- if freq_doubler %}
			adi,freq-doubler;
{%- endif %}
{%- if ref_crystal %}
			adi,ref-crystal;
{%- endif %}
			/* TODO: configure ref-input-clk, pll-clk, output-clk sub-nodes per application */
		};
