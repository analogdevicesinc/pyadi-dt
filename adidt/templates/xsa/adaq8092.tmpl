{# ADAQ8092 dual-channel DAQ SPI device node — UNTESTED, generated from kernel binding iio/adc/adi,adaq8092.yaml #}
		{{ label }}: adaq8092@{{ cs }} {
			compatible = "adi,adaq8092";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
{%- if clks_str is not none %}
			clocks = {{ clks_str }};
			clock-names = "clkin";
{%- endif %}
		};
