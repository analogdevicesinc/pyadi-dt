{# AD9084 converter SPI device node (SPI child, wrapped in &spi_bus { ... }) #}
		{{ label }}: ad9084@{{ cs }} {
			compatible = "adi,ad9084";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
{%- if reset_gpio is not none %}
			reset-gpios = <&{{ gpio_label }} {{ reset_gpio }} 0>;
{%- endif %}
{%- if dev_clk_ref is not none %}
			clocks = <&{{ dev_clk_ref }}>;
			clock-names = "dev_clk";
{%- endif %}
{%- if dev_clk_scales is not none %}
			dev_clk-clock-scales = <{{ dev_clk_scales }}>;
{%- endif %}
{%- if firmware_name is not none %}
			adi,device-profile-fw-name = "{{ firmware_name }}";
{%- endif %}
			#clock-cells = <1>;
			clock-output-names = "rx_sampl_clk", "tx_sampl_clk";
{%- if hsci_label is not none %}
			adi,axi-hsci-connected = <&{{ hsci_label }}>;
{%- endif %}
{%- if hsci_auto_linkup %}
			adi,hsci-auto-linkup-mode-en;
{%- endif %}
{%- if subclass is not none %}
			adi,subclass = <{{ subclass }}>;
{%- endif %}
{%- if side_b_separate_tpl %}
			adi,side-b-use-seperate-tpl-en;
{%- endif %}
{%- if jrx0_physical_lane_mapping is not none %}
			adi,jrx0-physical-lane-mapping = <{{ jrx0_physical_lane_mapping }}>;
{%- endif %}
{%- if jtx0_logical_lane_mapping is not none %}
			adi,jtx0-logical-lane-mapping = <{{ jtx0_logical_lane_mapping }}>;
{%- endif %}
{%- if jrx1_physical_lane_mapping is not none %}
			adi,jrx1-physical-lane-mapping = <{{ jrx1_physical_lane_mapping }}>;
{%- endif %}
{%- if jtx1_logical_lane_mapping is not none %}
			adi,jtx1-logical-lane-mapping = <{{ jtx1_logical_lane_mapping }}>;
{%- endif %}
			jesd204-device;
			#jesd204-cells = <2>;
			jesd204-top-device = <0>;
			jesd204-ignore-errors;
			jesd204-link-ids = <{{ link_ids }}>;
			jesd204-inputs = {{ jesd204_inputs }};
		};
