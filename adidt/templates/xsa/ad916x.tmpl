{# AD916x wideband DAC SPI device node — UNTESTED, generated from kernel binding iio/frequency/ad916x.yaml #}
{# Covers: adi,ad9161, adi,ad9162, adi,ad9163, adi,ad9164, adi,ad9166 #}
		{{ label }}: {{ compatible_id | default("ad9162") }}@{{ cs }} {
			compatible = "adi,{{ compatible_id | default("ad9162") }}";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
{%- if clks_str is not none %}
			clocks = {{ clks_str }};
			clock-names = {{ clk_names_str }};
{%- endif %}
{%- if interpolation is defined and interpolation is not none %}
			adi,interpolation = <{{ interpolation }}>;
{%- endif %}
			jesd204-device;
			#jesd204-cells = <2>;
			jesd204-top-device = <{{ jesd204_top_device | default(0) }}>;
			jesd204-link-ids = <{{ jesd204_link_ids | join(' ') }}>;
			jesd204-inputs = <&{{ jesd204_inputs }}>;
{%- if octets_per_frame is defined and octets_per_frame is not none %}
			adi,octets-per-frame = <{{ octets_per_frame }}>;
{%- endif %}
{%- if frames_per_multiframe is defined and frames_per_multiframe is not none %}
			adi,frames-per-multiframe = <{{ frames_per_multiframe }}>;
{%- endif %}
{%- if converters_per_device is defined and converters_per_device is not none %}
			adi,converters-per-device = <{{ converters_per_device }}>;
{%- endif %}
{%- if lanes_per_device is defined and lanes_per_device is not none %}
			adi,lanes-per-device = <{{ lanes_per_device }}>;
{%- endif %}
{%- if subclass is defined and subclass is not none %}
			adi,subclass = <{{ subclass }}>;
{%- endif %}
		};
