{# ADF4377/ADF4378 microwave synthesizer SPI device node — UNTESTED, generated from kernel binding iio/frequency/adi,adf4377.yaml #}
		{{ label }}: {{ compatible_id | default("adf4377") }}@{{ cs }} {
			compatible = "adi,{{ compatible_id | default("adf4377") }}";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
{%- if clks_str is not none %}
			clocks = {{ clks_str }};
			clock-names = "ref_in";
{%- endif %}
{%- if muxout_select is defined and muxout_select is not none %}
			adi,muxout-select = "{{ muxout_select }}";
{%- endif %}
		};
