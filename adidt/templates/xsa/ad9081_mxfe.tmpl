{# AD9081 MxFE device node (SPI child node, wrapped in &adc_spi { ... }) #}
{% from "_jesd_macros.tmpl" import mxfe_jesd_link %}
		{{ label }}: ad9081@{{ cs }} {
			compatible = "adi,ad9081";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
			reset-gpios = <&{{ gpio_label }} {{ reset_gpio }} 0>;
			sysref-req-gpios = <&{{ gpio_label }} {{ sysref_req_gpio }} 0>;
			rx2-enable-gpios = <&{{ gpio_label }} {{ rx2_enable_gpio }} 0>;
			rx1-enable-gpios = <&{{ gpio_label }} {{ rx1_enable_gpio }} 0>;
			tx2-enable-gpios = <&{{ gpio_label }} {{ tx2_enable_gpio }} 0>;
			tx1-enable-gpios = <&{{ gpio_label }} {{ tx1_enable_gpio }} 0>;
			clocks = <&{{ dev_clk_ref }}>;
			clock-names = "dev_clk";
			#clock-cells = <1>;
			clock-output-names = "rx_sampl_clk", "tx_sampl_clk";
			jesd204-device;
			#jesd204-cells = <2>;
			jesd204-top-device = <0>;
			jesd204-link-ids = <{{ rx_link_id }} {{ tx_link_id }}>;
			jesd204-inputs = <&{{ rx_core_label }} 0 {{ rx_link_id }}>, <&{{ tx_core_label }} 0 {{ tx_link_id }}>;
			adi,tx-dacs {
				#size-cells = <0>;
				#address-cells = <1>;
				adi,dac-frequency-hz = /bits/ 64 <{{ dac_frequency_hz }}>;
				adi,main-data-paths {
					#address-cells = <1>;
					#size-cells = <0>;
					adi,interpolation = <{{ tx_cduc_interpolation }}>;
					dac@0 { reg = <0>; };
					dac@1 { reg = <1>; };
					dac@2 { reg = <2>; };
					dac@3 { reg = <3>; };
				};
				adi,channelizer-paths {
					#address-cells = <1>;
					#size-cells = <0>;
					adi,interpolation = <{{ tx_fduc_interpolation }}>;
					ad9081_tx_fddc_chan0: channel@0 { reg = <0>; };
					ad9081_tx_fddc_chan1: channel@1 { reg = <1>; };
					ad9081_tx_fddc_chan2: channel@2 { reg = <2>; };
					ad9081_tx_fddc_chan3: channel@3 { reg = <3>; };
					ad9081_tx_fddc_chan4: channel@4 { reg = <4>; };
					ad9081_tx_fddc_chan5: channel@5 { reg = <5>; };
					ad9081_tx_fddc_chan6: channel@6 { reg = <6>; };
					ad9081_tx_fddc_chan7: channel@7 { reg = <7>; };
				};
{{- mxfe_jesd_link(tx_converter_select, tx_lane_map, tx_link_mode, tx_m, tx_f, tx_k, tx_l, tx_s) }}
			};
			adi,rx-adcs {
				#size-cells = <0>;
				#address-cells = <1>;
				adi,adc-frequency-hz = /bits/ 64 <{{ adc_frequency_hz }}>;
				adi,main-data-paths {
					#address-cells = <1>;
					#size-cells = <0>;
					adc@0 { reg = <0>; adi,decimation = <{{ rx_cddc_decimation }}>; };
					adc@1 { reg = <1>; adi,decimation = <{{ rx_cddc_decimation }}>; };
					adc@2 { reg = <2>; adi,decimation = <{{ rx_cddc_decimation }}>; };
					adc@3 { reg = <3>; adi,decimation = <{{ rx_cddc_decimation }}>; };
				};
				adi,channelizer-paths {
					#address-cells = <1>;
					#size-cells = <0>;
					ad9081_rx_fddc_chan0: channel@0 { reg = <0>; adi,decimation = <{{ rx_fddc_decimation }}>; };
					ad9081_rx_fddc_chan1: channel@1 { reg = <1>; adi,decimation = <{{ rx_fddc_decimation }}>; };
					ad9081_rx_fddc_chan2: channel@2 { reg = <2>; adi,decimation = <{{ rx_fddc_decimation }}>; };
					ad9081_rx_fddc_chan3: channel@3 { reg = <3>; adi,decimation = <{{ rx_fddc_decimation }}>; };
					ad9081_rx_fddc_chan4: channel@4 { reg = <4>; adi,decimation = <{{ rx_fddc_decimation }}>; };
					ad9081_rx_fddc_chan5: channel@5 { reg = <5>; adi,decimation = <{{ rx_fddc_decimation }}>; };
					ad9081_rx_fddc_chan6: channel@6 { reg = <6>; adi,decimation = <{{ rx_fddc_decimation }}>; };
					ad9081_rx_fddc_chan7: channel@7 { reg = <7>; adi,decimation = <{{ rx_fddc_decimation }}>; };
				};
{{- mxfe_jesd_link(rx_converter_select, rx_lane_map, rx_link_mode, rx_m, rx_f, rx_k, rx_l, rx_s) }}
			};
		};
