{# AD7768/AD7768-4 sigma-delta ADC SPI device node — UNTESTED, generated from kernel binding iio/adc/adi,ad7768.yaml #}
		{{ label }}: {{ compatible_id | default("ad7768") }}@{{ cs }} {
			compatible = "adi,{{ compatible_id | default("ad7768") }}";
			reg = <{{ cs }}>;
			spi-max-frequency = <{{ spi_max_hz }}>;
{%- if clks_str is not none %}
			clocks = {{ clks_str }};
			clock-names = "mclk";
{%- endif %}
{%- if dma_label is not none %}
			dmas = <&{{ dma_label }} 0>;
			dma-names = "rx";
{%- endif %}
{%- if data_lines is defined and data_lines is not none %}
			adi,data-lines = <{{ data_lines }}>;
{%- endif %}
{%- if reset_gpio is not none %}
			reset-gpios = <&{{ gpio_label }} {{ reset_gpio }} 0>;
{%- endif %}
		};
