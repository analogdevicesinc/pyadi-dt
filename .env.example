# =============================================================================
# Hardware Test Configuration
# =============================================================================
# Copy this file to .env and uncomment the variables you need.
# .env is gitignored and loaded automatically by pytest-dotenv.
#
# Two connection modes are supported:
#
#   1. Coordinator mode  — set LG_COORDINATOR (and optionally LG_ENV)
#   2. Direct mode       — set LG_ENV only
#
# If both LG_COORDINATOR and LG_ENV are set, labgrid connects to the
# coordinator using the env YAML for target/place definitions.
# If only LG_COORDINATOR is set, exporter sub-mode variables control
# how the target is acquired (see below).
# =============================================================================

# -- Coordinator mode ---------------------------------------------------------
# LG_COORDINATOR=10.0.0.41:20408

# -- Exporter sub-modes (only used when LG_COORDINATOR is set) ---------------

# Discovery: exporter already running, places published to coordinator.
# No additional variables needed beyond LG_COORDINATOR.

# Single-spawn: test session starts one exporter (all three required).
# LG_EXPORTER_HOST=mini2
# LG_EXPORTER_NAME=mini2
# LG_EXPORTER_YAML=examples/lg_ad9081_zcu102_mini2_exporter.yaml

# Multi-spawn: test session starts exporters per config file.
# LG_EXPORTERS_CONFIG=tests/coordinator/exporters_all.yaml

# -- Direct mode (legacy) ----------------------------------------------------
# LG_ENV=/jenkins/lg_ad9081_zcu102.yaml

# -- Build options ------------------------------------------------------------
# ADI_XSA_BUILD_KERNEL=1
